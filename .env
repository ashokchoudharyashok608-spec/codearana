# ╔══════════════════════════════════════════════════════════════════════╗
# ║                    CodeArena — Environment Variables                  ║
# ║  Copy this file to .env and fill in your values before running.      ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:4200
PORT=3000

# ── Database (SQLite) ────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Judge0 ───────────────────────────────────────────────────────────────────
JUDGE0_URL=https://api.judge0.com

# ── Secrets ──────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
ENCRYPTION_KEY=your_encryption_key_32_chars

# ── Optional (Stripe, OAuth, etc.) ────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_secret
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@codearena.dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_BYTES_HEX
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_RANDOM_64_BYTES_HEX

# ── Judge0 ───────────────────────────────────────────────────────────────────
JUDGE0_URL=http://judge0:2358
JUDGE0_AUTH_TOKEN=change_me_judge0_auth_token

# ── Encryption (for test case data at rest) ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_BYTES_HEX

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Subscription Price IDs (create in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_REPLACE_PRO_MONTHLY
STRIPE_ELITE_PRICE_ID=price_REPLACE_ELITE_MONTHLY

# ── OAuth: Google ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE

# ── OAuth: GitHub ─────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=REPLACE_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_GITHUB_CLIENT_SECRET

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.REPLACE
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=CodeArena

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:4200,https://yourdomain.com
